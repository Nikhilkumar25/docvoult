generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  name             String
  createdAt        DateTime          @default(now())
  documents        Document[]
  folders          Folder[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[] @relation("UserMemberships")
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  documents Document[]
  folders   Folder[]
  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userEmail   String
  userId      String?
  createdAt   DateTime  @default(now())
  user        User?     @relation("UserMemberships", fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userEmail])
  @@index([workspaceId])
  @@index([userEmail])
}

model Folder {
  id          String     @id @default(cuid())
  name        String
  userId      String
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspaceId String?
  documents   Document[]
  parent      Folder?    @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]   @relation("FolderToFolder")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([workspaceId])
  @@index([parentId])
}

model Document {
  id            String         @id @default(cuid())
  title         String
  fileName      String
  fileUrl       String
  fileSize      Int
  pageCount     Int            @default(1)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  folderId      String?
  workspaceId   String?
  comments      Comment[]
  folder        Folder?        @relation(fields: [folderId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id])
  knowledgeBase KnowledgeBase?
  links         Link[]
  views         View[]

  @@index([userId])
  @@index([workspaceId])
  @@index([folderId])
}

model Link {
  id               String    @id @default(cuid())
  slug             String    @unique
  documentId       String
  requireEmail     Boolean   @default(false)
  passcode         String?
  expiresAt        DateTime?
  allowDownload    Boolean   @default(false)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  requireWatermark Boolean   @default(false)
  enableAI         Boolean   @default(false)
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  views            View[]

  @@index([documentId])
  @@index([slug])
}

model View {
  id             String     @id @default(cuid())
  viewerEmail    String?
  viewerName     String?
  linkId         String
  documentId     String
  startedAt      DateTime   @default(now())
  lastActiveAt   DateTime   @default(now())
  completedPages Int        @default(0)
  duration       Int        @default(0)
  comments       Comment[]
  pageViews      PageView[]
  document       Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  link           Link       @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([documentId])
}

model PageView {
  id         String   @id @default(cuid())
  viewId     String
  pageNumber Int
  duration   Int      @default(0)
  enteredAt  DateTime @default(now())
  view       View     @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@index([viewId])
}

model Comment {
  id         String    @id @default(cuid())
  text       String
  documentId String
  viewId     String?
  userName   String?
  pageNumber Int?
  createdAt  DateTime  @default(now())
  askerEmail String?
  response   String?
  responseAt DateTime?
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  view       View?     @relation(fields: [viewId], references: [id])

  @@index([documentId])
  @@index([viewId])
}

model KnowledgeBase {
  id         String               @id @default(cuid())
  documentId String               @unique
  status     String               @default("pending")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  entries    KBEntry[]
  document   Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  unanswered UnansweredQuestion[]
}

model KBEntry {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  question        String
  answer          String        @default("")
  category        String        @default("general")
  embedding       String?
  isApproved      Boolean       @default(false)
  sortOrder       Int           @default(0)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
}

model UnansweredQuestion {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  question        String
  count           Int           @default(1)
  createdAt       DateTime      @default(now())
  lastAskedAt     DateTime      @default(now())
  dismissed       Boolean       @default(false)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
}
