generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  name             String
  createdAt        DateTime          @default(now())
  documents        Document[]
  folders          Folder[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[] @relation("UserMemberships")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]
  documents Document[]
  folders   Folder[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userEmail   String
  userId      String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation("UserMemberships", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userEmail])
  @@index([workspaceId])
  @@index([userEmail])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  userId      String
  workspaceId String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  parent    Folder?    @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderToFolder")
  documents Document[]

  @@index([userId])
  @@index([workspaceId])
  @@index([parentId])
}

model Document {
  id          String    @id @default(cuid())
  title       String
  fileName    String
  fileUrl     String
  fileSize    Int
  pageCount   Int       @default(1)
  userId      String
  workspaceId String?
  folderId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  links       Link[]
  views       View[]
  comments    Comment[]

  @@index([userId])
  @@index([workspaceId])
  @@index([folderId])
}

model Link {
  id               String    @id @default(cuid())
  slug             String    @unique
  documentId       String
  requireEmail     Boolean   @default(false)
  passcode         String?
  expiresAt        DateTime?
  allowDownload    Boolean   @default(false)
  requireWatermark Boolean   @default(false)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  views            View[]

  @@index([documentId])
  @@index([slug])
}

model View {
  id             String     @id @default(cuid())
  viewerEmail    String?
  viewerName     String?
  linkId         String
  documentId     String
  startedAt      DateTime   @default(now())
  lastActiveAt   DateTime   @default(now())
  completedPages Int        @default(0)
  duration       Int        @default(0)
  link           Link       @relation(fields: [linkId], references: [id], onDelete: Cascade)
  document       Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  pageViews      PageView[]
  comments       Comment[]

  @@index([linkId])
  @@index([documentId])
}

model PageView {
  id         String   @id @default(cuid())
  viewId     String
  pageNumber Int
  duration   Int      @default(0)
  enteredAt  DateTime @default(now())
  view       View     @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@index([viewId])
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  documentId String
  viewId     String?
  userName   String?
  askerEmail String?
  pageNumber Int?
  response   String?
  responseAt DateTime?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  view     View?    @relation(fields: [viewId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([viewId])
}
