{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "docvoult",
    "compatibility_date": "2025-07-18",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "main": ".open-next/worker.js",
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "observability": {
        "enabled": true
    }
}