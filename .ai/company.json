{
  "company": {
    "name": "DocsVault HQ",
    "mission": "Build and grow DocsVault into a self-sustaining AI-powered secure document sharing platform through continuous R&D and automated feature implementation.",
    "board": [
      {
        "name": "Nikhil Aggarwal",
        "role": "CEO / Board",
        "email": "nikhil.aggarwal@zomato.com",
        "approvalRequired": true,
        "notes": "All PR merges to 'main' require Nikhil's manual review and approval."
      }
    ]
  },
  "governance": {
    "mergePolicy": {
      "targetBranch": "main",
      "sourceBranch": "ai",
      "requiresBoardApproval": true,
      "autoMerge": false,
      "description": "All AI changes are committed to 'ai' branch. Merges to 'main' require manual board approval."
    }
  },
  "agents": [
    {
      "id": "docsvault-engine",
      "name": "DocsVault Engine",
      "role": "pm_engineer",
      "provider": "anthropic",
      "model": "",
      "skillsPath": ".ai/agents/engine/SKILLS.md",
      "codingTool": "antigravity",
      "heartbeat": {
        "schedule": "0 9 * * 1",
        "timezone": "Asia/Kolkata",
        "description": "Weekly R&D + Implementation: Mondays at 9:00 AM IST"
      },
      "budget": {
        "monthlyLimitUSD": 20
      },
      "adapterConfig": {
        "command": "/Users/nikhil.aggarwal@zomato.com/.gemini/antigravity/scratch/docvault/.ai/bin/claude",
        "env": {
          "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
        }
      },
      "capabilities": [
        "web_search",
        "database_read_only",
        "read_codebase",
        "write_code"
      ],
      "outputs": [
        "Code changes on 'ai' branch",
        "Pull Requests to 'main'",
        ".ai/ENGINE_LOG.md updates"
      ]
    },
    {
      "id": "marketing-manager",
      "name": "Marketing Manager",
      "role": "cmo",
      "provider": "anthropic",
      "model": "",
      "skillsPath": ".ai/agents/marketing-manager/SKILLS.md",
      "adapterConfig": {
        "command": "/Users/nikhil.aggarwal@zomato.com/.gemini/antigravity/scratch/docvault/.ai/bin/claude",
        "env": {
          "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
        }
      },
      "heartbeat": {
        "schedule": "0 10 * * 5",
        "timezone": "Asia/Kolkata",
        "description": "Weekly Social Planning: Fridays at 10:00 AM IST"
      },
      "budget": {
        "monthlyLimitUSD": 5
      },
      "capabilities": [
        "web_search",
        "read_git_log"
      ],
      "outputs": [
        ".ai/SOCIAL_CALENDAR.md updates"
      ]
    }
  ],
  "orgChart": {
    "board": "Nikhil Aggarwal (Human)",
    "structure": {
      "DocsVault Engine": {
        "reports_to": "Board",
        "collaborates_with": ["Marketing Manager"]
      },
      "Marketing Manager": {
        "reports_to": "Board",
        "collaborates_with": ["DocsVault Engine"]
      }
    }
  }
